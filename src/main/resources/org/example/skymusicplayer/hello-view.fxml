<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.skymusicplayer.HelloController"
           prefWidth="900" prefHeight="500">

<HBox spacing="15"> <padding>
    <Insets bottom="20" left="20" right="20" top="20"/>
</padding>

    <VBox spacing="12" alignment="TOP_CENTER" prefWidth="240">
        <Label text="Sky 自动弹奏" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <TextField fx:id="filePathField" promptText="当前未选定曲目" editable="false"/>
        <Label fx:id="statusLabel" text="状态: 等待中..." wrapText="true" alignment="CENTER" textAlignment="CENTER" prefHeight="40"/>
        <Slider fx:id="progressSlider" min="0" max="1" value="0" maxWidth="Infinity"/>

        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="速度 (F4-/F5+):" style="-fx-font-size: 12px;"/>
            <Slider fx:id="speedSlider" min="0.5" max="2.0" value="1.0" blockIncrement="0.1" HBox.hgrow="ALWAYS"/>
            <Label fx:id="speedLabel" text="1.0x" style="-fx-font-size: 12px;" prefWidth="38"/>
        </HBox>

        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="倒计时:" style="-fx-font-size: 12px;"/>
            <Spinner fx:id="countdownSpinner" prefWidth="65"/>
            <Label text="秒" style="-fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <ToggleButton fx:id="audioModeToggle" text="🎵 试听" style="-fx-font-size: 11px;"/>
        </HBox>

        <VBox spacing="8">
            <Button text="▶ 开始演奏 (F1)" onAction="#onStartPlayClick" maxWidth="Infinity" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <HBox spacing="6">
                <Button text="⏸ 暂停 (F2)" onAction="#onPauseClick" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #607D8B; -fx-text-fill: white;"/>
                <Button text="▶ 继续 (F3)" onAction="#onResumeClick" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-background-color: #03A9F4; -fx-text-fill: white;"/>
            </HBox>
            <Button text="⏹ 停止 (F6)" onAction="#onStopPlayClick" maxWidth="Infinity" style="-fx-background-color: #F44336; -fx-text-fill: white;"/>
            <Button text="🔄 刷新曲目库" onAction="#refreshLibrary" maxWidth="Infinity"/>
            <Button text="📁 导入曲谱" onAction="#onImportClick" maxWidth="Infinity"/>
            <Button text="➕ 创建歌曲" onAction="#onCreateClick" maxWidth="Infinity" style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
            <Button text="✏ 编辑曲谱" onAction="#onEditClick" maxWidth="Infinity" style="-fx-background-color: #9C27B0; -fx-text-fill: white;"/>
        </VBox>
    </VBox>

    <VBox spacing="5" HBox.hgrow="ALWAYS" prefWidth="240">
        <Label text="曲目库 (右键加标签):" style="-fx-font-weight: bold;"/>
        <HBox spacing="4">
            <ComboBox fx:id="filterCombo" prefWidth="100"/>
            <TextField fx:id="searchField" promptText="🔍 搜索..." HBox.hgrow="ALWAYS"/>
        </HBox>
        <ListView fx:id="songListView" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox spacing="10" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 12;">
        <Label text="🎹 虚拟琴键 (3×5)" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
        <Label text="点击单元格 → 按键盘任意键 重映射" style="-fx-font-size: 10px; -fx-text-fill: gray;"/>

        <GridPane fx:id="pianoGrid" hgap="6" vgap="6">
            <Button fx:id="pianoKey0" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Button fx:id="pianoKey1" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Button fx:id="pianoKey2" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <Button fx:id="pianoKey3" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <Button fx:id="pianoKey4" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="4" GridPane.rowIndex="0"/>

            <Button fx:id="pianoKey5" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Button fx:id="pianoKey6" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Button fx:id="pianoKey7" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <Button fx:id="pianoKey8" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <Button fx:id="pianoKey9" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="4" GridPane.rowIndex="1"/>

            <Button fx:id="pianoKey10" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Button fx:id="pianoKey11" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <Button fx:id="pianoKey12" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <Button fx:id="pianoKey13" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
            <Button fx:id="pianoKey14" prefWidth="55" prefHeight="55" onAction="#onPianoKeyClick" GridPane.columnIndex="4" GridPane.rowIndex="2"/>
        </GridPane>

        <Separator/>
        <Button text="💾 保存按键配置" onAction="#saveConfig" maxWidth="Infinity" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
    </VBox>
</HBox>

<ToggleButton fx:id="themeToggle" text="🌙" StackPane.alignment="TOP_RIGHT"
              style="-fx-font-size: 13px; -fx-padding: 2 7 2 7; -fx-background-radius: 12; -fx-opacity: 0.75;">
    <StackPane.margin>
        <Insets top="6" right="6"/>
    </StackPane.margin>
</ToggleButton>
</StackPane>
